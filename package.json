{
	"name": "cantor",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"check:imports": "bun ./scripts/check-imports.mjs",
		"check:contracts": "bun ./scripts/check-public-api-contracts.mjs",
		"update:contracts": "bun ./scripts/check-public-api-contracts.mjs --write",
		"check:all": "bun run check:imports && bun run check:contracts && bun run typecheck && bun run lint && bun run test && bun run build",
		"prebuild": "bun run check:imports && bun run check:contracts && bun run typecheck && bun run lint",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run",
		"test:view": "vitest --run 'src/view'",
		"test:core": "vitest --run --exclude 'src/view/**/*.test.ts'",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/svelte": "^1.1.2",
		"@internationalized/date": "^3.12.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/dompurify": "^3.2.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "4.1.1",
		"bits-ui": "^2.16.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"lint-staged": {
		"*.{ts,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{js,json,css,md,html}": "prettier --write"
	},
	"dependencies": {
		"@mlc-ai/web-llm": "^0.2.82",
		"dompurify": "^3.3.3",
		"function-plot": "^1.25.3",
		"jszip": "^3.10.1",
		"katex": "^0.16.42",
		"lucide-svelte": "^1.0.1",
		"marked": "^17.0.5",
		"plotly.js-dist-min": "^3.4.0",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"xstate": "^5.29.0"
	}
}
